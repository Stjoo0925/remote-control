<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="local.corp.remote_control_agent">

    <!-- ────────────────────────────────────────────────────────── -->
    <!-- 권한                                                        -->
    <!-- ────────────────────────────────────────────────────────── -->

    <!-- 인터넷 (Signaling 서버 + WebRTC) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 포그라운드 서비스 (백그라운드 실행 유지) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- 화면 캡처 (MediaProjection) — 런타임에 사용자 승인 필요 -->
    <!-- 실제 권한은 MediaProjectionManager.createScreenCaptureIntent()로 획득 -->

    <!-- 진동 (연결 요청 알림) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- 알림 표시 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 부팅 완료 시 자동 시작 (선택) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 접근성 서비스 (입력 제어) -->
    <!-- 사용자가 설정 > 접근성에서 수동 활성화 필요 -->

    <application
        android:label="원격 제어 에이전트"
        android:name="${applicationName}"
        android:icon="@android:drawable/sym_def_app_icon"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:usesCleartextTraffic="false">

        <!-- Flutter 메인 액티비티 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 포그라운드 서비스 — Signaling + WebRTC 세션 유지 -->
        <service
            android:name=".RemoteControlService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice"
            android:stopWithTask="false" />

        <!-- 접근성 서비스 — 원격 입력 제어 -->
        <service
            android:name=".RemoteInputAccessibilityService"
            android:exported="true"
            android:label="원격 입력 제어"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 부팅 시 자동 시작 리시버 -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- FlutterEngine 캐시 -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>
