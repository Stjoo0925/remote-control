# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# App Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=remote_control
POSTGRES_USER=rc_user
POSTGRES_PASSWORD=change_me
# Prisma DATABASE_URL (used by prisma migrate)
DATABASE_URL=postgresql://rc_user:change_me@localhost:5432/remote_control

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://localhost:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT Authentication
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_SECRET_KEY=change_me_to_strong_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LDAP / Active Directory
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LDAP_SERVER=ldap://ldap.corp.local
LDAP_BASE_DN=DC=corp,DC=local
LDAP_BIND_DN=CN=svc-remote,OU=ServiceAccounts,DC=corp,DC=local
LDAP_BIND_PASSWORD=change_me

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TURN / STUN (coturn)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TURN_SERVER=turn:turn.corp.local:3478
TURN_USERNAME=remote_user
TURN_PASSWORD=change_me

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Frontend (Vite) - VITE_ prefix required
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000
VITE_STUN_URL=stun:stun.corp.local:3478
VITE_TURN_URL=turn:turn.corp.local:3478
VITE_TURN_USER=remote_user
VITE_TURN_PASS=change_me
