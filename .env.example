# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# App
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=remote_control
POSTGRES_USER=rc_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://rc_user:your_secure_password_here@localhost:5432/remote_control

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://localhost:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT — 반드시 강력한 임의 문자열로 변경!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_SECRET_KEY=replace_with_long_random_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 인증 모드
#   local — 이메일/비밀번호 (기본, 인터넷 배포 권장)
#   ldap  — 사내 AD 전용
#   both  — 둘 다 허용
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AUTH_MODE=local
ALLOW_REGISTRATION=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LDAP (AUTH_MODE=ldap 또는 both 시에만 설정)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LDAP_SERVER=ldap://ldap.example.com
# LDAP_BASE_DN=DC=example,DC=com
# LDAP_BIND_DN=CN=svc-account,OU=ServiceAccounts,DC=example,DC=com
# LDAP_BIND_PASSWORD=ldap_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TURN / STUN
#   기본값: 구글 공개 STUN (별도 설정 불필요)
#   자체 TURN 릴레이가 있으면 아래 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TURN_SERVERS=turn:your-turn-server.com:3478,stun:stun.l.google.com:19302
# TURN_USERNAME=turn_user
# TURN_PASSWORD=turn_password
# TURN_PUBLIC_IP=203.0.113.10   ← coturn 컨테이너의 공인 IP

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CORS — 기본: 전체 허용
#   특정 도메인으로 제한: CORS_ORIGINS=["https://your-domain.com"]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CORS_ORIGINS=["*"]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Frontend (Vite)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 비워 두면 현재 호스트를 자동으로 사용 (권장)
# VITE_API_BASE_URL=https://your-domain.com/api
# VITE_WS_URL=wss://your-domain.com
VITE_STUN_URL=stun:stun.l.google.com:19302
# VITE_TURN_URL=turn:your-turn-server.com:3478
# VITE_TURN_USER=turn_user
# VITE_TURN_PASS=turn_password
