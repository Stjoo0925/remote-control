# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# App Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=remote_control
POSTGRES_USER=rc_user
POSTGRES_PASSWORD=change_me
# Prisma DATABASE_URL (used by prisma migrate)
DATABASE_URL=postgresql://rc_user:change_me@localhost:5432/remote_control

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://localhost:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT Authentication
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_SECRET_KEY=change_me_to_strong_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 인증 모드
# "ldap"  — 사내 AD만 (LDAP 서버 필요)
# "local" — 이메일/비밀번호 로컬 계정만
# "both"  — 둘 다 허용 (LDAP 우선)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AUTH_MODE=both
# 로컬 자유 회원가입 허용 (false면 관리자가 계정 생성)
ALLOW_REGISTRATION=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LDAP / Active Directory (AUTH_MODE=ldap 또는 both 시 필요)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LDAP_SERVER=ldap://ldap.corp.local
LDAP_BASE_DN=DC=corp,DC=local
LDAP_BIND_DN=CN=svc-remote,OU=ServiceAccounts,DC=corp,DC=local
LDAP_BIND_PASSWORD=change_me

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TURN / STUN (coturn) — NAT 통과 설정
# 인터넷 연결 시 공인 IP/도메인으로 변경 필수
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 쉼표로 복수 서버 지정 가능
# 예: TURN_SERVERS=turn:my-server.com:3478,stun:stun.l.google.com:19302
TURN_SERVERS=turn:turn.corp.local:3478
TURN_USERNAME=remote_user
TURN_PASSWORD=change_me
# coturn 컨테이너의 공인 IP (인터넷 배포 시 필수)
TURN_PUBLIC_IP=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Frontend (Vite) - VITE_ prefix required
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000
# STUN/TURN 서버 (공인 주소로 변경)
VITE_STUN_URL=stun:stun.l.google.com:19302
VITE_TURN_URL=turn:turn.corp.local:3478
VITE_TURN_USER=remote_user
VITE_TURN_PASS=change_me
